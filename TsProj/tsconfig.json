{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": false,
    "noEmitOnError": true
  },
  "include": [
    "src/**/*.ts",
    "types/**/*.d.ts",
    "../My project/Assets/Package/core/Typing/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
